rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Unified Authorization Helper (Correct Firestore Syntax)
    function isAuthorized(perm) {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'member') in ['owner', 'admin', 'manager', 'Owner', 'Admin', 'Manager'] ||
        (perm != null && perm in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', []))
      );
    }

    // --- COLLECTIONS ---

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if (request.auth != null && request.auth.uid == userId) || 
                      (isAuthorized('menuRoles') || isAuthorized('menuApprovals')) && 
                      (!exists(/databases/$(database)/documents/users/$(userId)) || 
                       get(/databases/$(database)/documents/users/$(userId)).data.get('role', 'member') != 'owner');
    }

    match /announcements/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized('menuAnnouncements');
    }

    match /deposits/{depId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAuthorized('menuApprovals');
    }

    match /investments/{invId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized('menuInvestments');
    }

    match /system/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized('menuRoles') || isAuthorized('menuApprovals') || isAuthorized('menuReports');
    }

    match /expenses/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized('menuExpenses');
    }

    match /companyAccount/{docId} {
      allow read: if isAuthorized('menuCompanyAccount');
      allow create: if isAuthorized('menuApprovals') || isAuthorized('menuCompanyAccount');
      allow update, delete: if isAuthorized('menuCompanyAccount');
    }
    
    match /archivedMembers/{docId} {
      allow read: if isAuthorized('menuReports');
      allow write: if isAuthorized('menuRoles');
    }
  }
}
