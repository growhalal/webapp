service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check roles
    function hasRole(role) {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if hasRole('owner') || 
                      ( (hasRole('admin') || hasRole('manager')) && 
                        (!exists(/databases/$(database)/documents/users/$(userId)) || 
                         (get(/databases/$(database)/documents/users/$(userId)).data.role != 'owner' && 
                          get(/databases/$(database)/documents/users/$(userId)).data.email != 'growhalal0@gmail.com')) ) ||
                      (request.auth != null && request.auth.uid == userId);
    }

    // Announcements
    match /announcements/{annId} {
      allow read: if request.auth != null;
      allow write: if hasRole('owner') || hasRole('admin');
    }

    // Deposits
    match /deposits/{depId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if hasRole('owner') || hasRole('manager');
    }

    // Investments
    match /investments/{invId} {
      allow read: if request.auth != null;
      allow write: if hasRole('owner') || hasRole('manager');
    }

    // System Stats
    match /system/{docId} {
      allow read: if request.auth != null;
      allow write: if hasRole('owner') || hasRole('manager');
    }

    // Expenses
    match /expenses/{expId} {
      allow read: if request.auth != null;
      allow write: if hasRole('owner') || hasRole('admin') || hasRole('manager') || 
                   (request.auth != null && "menuExpenses" in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions);
    }
  }
}
